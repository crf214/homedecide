# ── Supabase ──────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Database (Prisma) ──────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL for DATABASE_URL
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
# Use the direct connection for DIRECT_URL (migrations)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# ── Session secret (generate with: openssl rand -hex 32) ──
SESSION_SECRET=generate_a_random_32_char_secret_here

# ── Anthropic (for AI insights) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase Storage bucket name ──────────────────────────
SUPABASE_STORAGE_BUCKET=property-photos

# ── App URL ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
